// 2. Sum of two numbers

#include <iostream>
using namespace std;

int main() {
    int num1, num2, sum;

    cout << "Enter first number: ";
    cin >> num1;

    cout << "Enter second number: ";
    cin >> num2;

    sum = num1 + num2;

    cout << "Sum = " << sum << endl;

    return 0;
}


// 3. Area of rectangle

#include <iostream>
using namespace std;

int main() {
    float length, width, area;

    cout << "Enter length of rectangle: ";
    cin >> length;

    cout << "Enter width of rectangle: ";
    cin >> width;

    area = length * width;

    cout << "Area of rectangle = " << area << endl;

