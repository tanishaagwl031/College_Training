Employee el("xyz", 101);
el.display();
return 0;
}


// 3. Rectangle Area

#include <iostream>
using namespace std;
class Rectangle {
    public:
    int length, width;
    
    void setData(int l, int w) {
        length = l;
        width   = w;
    }
    
    int area()
    {
        return length * width;
        }
};
int main() {
Rectangle r;
r.setData(10, 5);
cout<<"Area = "<<r.area();
return 0;
}


// 4. Bank Account

#include <iostream>
using namespace std;
class BankAccount {
    public:
    double balance = 0;
    
    void deposit(double amount) {
        balance += amount;
    }
    
    void withdraw(double amount) {
        balance -= amount;
    }
    
    void display() {
        cout<<"Balance = "<<balance;
    }
};
int main() {
BankAccount b;
b.deposit(5000);
b.withdraw(2000);
b.display();
return 0;
}


// 5. Car + Static

#include <iostream>
using namespace std;
class Car {
    public:
    static int count;
    
    Car() {
        count++;
    }
};

int Car::count = 0;

int main() {
Car c1, c2, c3;
cout<<"Total Objects = "
<< Car::count;
return 0;
}


// 6. Box + this

#include <iostream>
using namespace std;
class Box {
    public:
    int length;
    
    void setLength(int length) {
        this->length = length;
    }
    void display() {
        cout<<"Length = "<<length;
    }
};
int main() {
Box b;
b.setLength(15);
b.display();
return 0;
}
