// 1. Student Class

#include <iostream>
using namespace std;
class Student {
    public:
    string name;
    int rollno;
    float marks;
    
    void display()
    {
        cout<<"Name: " <<name<<endl;
        cout<<"Roll No:" <<rollno<<endl;
        cout<<"Marks:" <<marks<<endl;
        }
};
int main() {
Student s;
s.name = "Tanisha";
s.rollno = 101;
s.marks = 90;
s.display();
return 0;
}


// 2. Employee Class

#include <iostream>
using namespace std;
class Employee {
    public:
    string name;
    int id;
    
