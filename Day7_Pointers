// 1. Print Address

#include <iostream>
using namespace std;

int main()
{
    int num = 10;

    // Pointer variable
    int *ptr = &num;

    cout << "Value of num = " << num << endl;
    cout << "Address of num = " << &num << endl;
    cout << "Address stored in pointer = " << ptr << endl;

    return 0;
}


// 2. Swap Using Pointers

#include <iostream>
using namespace std;

int main()
{
    int a, b, temp;

    cout << "Enter two numbers: ";
    cin >> a >> b;

    int *ptr1 = &a;
    int *ptr2 = &b;

    // Swap using pointers
    temp = *ptr1;
    *ptr1 = *ptr2;
    *ptr2 = temp;

    cout << "After swapping:" << endl;
    cout << "a = " << a << endl;
    cout << "b = " << b << endl;

    return 0;
}


// 3. Array Sum Using Pointers

#include <iostream>
using namespace std;

int main()
{
    int n, sum = 0;

    cout << "Enter the number of elements: ";
    cin >> n;

    int arr[n];

    cout << "Enter array elements: ";
    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int *ptr = arr;  // Pointer to the first element of the array

    for (int i = 0; i < n; i++)
    {
        sum += *(ptr + i);
    }

    cout << "Sum of array elements = " << sum << endl;

    return 0;
}


// 4. Largest Element Using Pointers

#include <iostream>
using namespace std;

int main()
{
    int n;

    cout << "Enter the number of elements: ";
    cin >> n;

    int arr[n];

    cout << "Enter array elements: ";
    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int *ptr = arr;
    int largest = *ptr;

    for (int i = 1; i < n; i++)
    {
        if (*(ptr + i) > largest)
        {
            largest = *(ptr + i);
        }
    }

    cout << "Largest element = " << largest << endl;

    return 0;
}


// 5. Traverse Array Using Pointers

#include <iostream>
using namespace std;

int main()
{
    int n;

    cout << "Enter the number of elements: ";
